<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="#30000000"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <TextView
                android:id="@+id/tvCapTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tabla de Referencia CAPECO"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvCapSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proporciones y materiales por m³"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="16dp"/>

            <!-- Tabla dinámica -->
            <LinearLayout
                android:id="@+id/containerTablaCapeco"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Tabla acero ASTM A615 -->
            <LinearLayout
                android:id="@+id/sectionAcero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Barras ASTM A615 — Pesos y Precios"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textColor="@color/mat_acero"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerTablaAcero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Nota -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="* Fuente: CAPECO — Cámara Peruana de la Construcción. Los valores son referenciales; usa siempre el diseño de mezclas aprobado."
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
