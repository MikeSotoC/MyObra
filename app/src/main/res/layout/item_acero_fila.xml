<?xml version="1.0" encoding="utf-8"?>
<!--
  Fila de metrado de acero — dos modos según el plano estructural:
  • BASTONES:      8Ø1/2"     → N° varillas + diámetro + longitud/varilla
  • DISTRIBUCIÓN:  Ø3/8"@0.20 → diámetro + @espaciado + L tramo + L/varilla
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp"
    android:paddingHorizontal="2dp">

    <!-- Row 1: Tipo + Diámetro + Eliminar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Toggle: bastones / @ -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginEnd="6dp">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipBastones"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="N°Ø"
                android:textSize="11sp"
                android:checked="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipDistribucion"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Ø@cm"
                android:textSize="11sp"/>
        </com.google.android.material.chip.ChipGroup>

        <!-- Diámetro (siempre visible) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDiam"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <AutoCompleteTextView
                android:id="@+id/dropDiam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="12sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Eliminar -->
        <ImageView
            android:id="@+id/btnEliminar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@android:drawable/ic_menu_delete"
            android:tint="?attr/colorError"
            android:contentDescription="Eliminar"/>
    </LinearLayout>

    <!-- Row 2a: BASTONES — N° varillas + longitud/varilla -->
    <LinearLayout
        android:id="@+id/layoutBastones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="visible">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCantidad"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="N° varillas"
            android:layout_marginEnd="6dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textSize="13sp"
                android:text="1"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLongitud"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Long. c/u (m)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLongitud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="13sp"
                android:text="9.00"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Row 2b: DISTRIBUCIÓN @ — espaciado + L tramo + L/varilla -->
    <LinearLayout
        android:id="@+id/layoutDistribucion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEspaciado"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="@cm"
            android:layout_marginEnd="4dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEspaciado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="13sp"
                android:text="0.20"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTramo"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="L tramo (m)"
            android:layout_marginHorizontal="4dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTramo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="13sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLongDistrib"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="L/var. (m)"
            android:layout_marginStart="4dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLongDistrib"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="13sp"
                android:text="9.00"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Divider entre filas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorSurfaceVariant"
        android:layout_marginTop="6dp"/>
</LinearLayout>
