<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?attr/colorBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="120dp"
            android:background="?attr/colorPrimary">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="fitXY" android:alpha="0.12"
                app:srcCompat="@drawable/ic_header_losas"
                android:contentDescription="@string/title_losas"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center_vertical" android:paddingHorizontal="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/title_losas" android:textSize="22sp"
                        android:textStyle="bold" android:textColor="@color/white"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/desc_losas" android:textSize="11sp"
                        android:textColor="#BDffffff" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- A. DATOS DE ENTRADA — una sola card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            app:cardElevation="2dp" app:cardCornerRadius="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card header bar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="14dp" android:background="?attr/colorSurfaceVariant">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="A.  DATOS DE ENTRADA"
                        android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.06"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTablaCapeco"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📊 Tabla CAPECO" android:textSize="11sp"
                        android:textColor="?attr/colorPrimary"
                        android:minHeight="0dp" android:paddingVertical="0dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">

                    <!-- A.1 Altura y tipo -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="A.1  Tipo de losa y relleno"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAlturaLosa"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Altura de losa" android:layout_marginBottom="8dp">
                        <AutoCompleteTextView android:id="@+id/dropAlturaLosa"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="none"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTipoLadrillo"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Material de relleno" android:layout_marginBottom="16dp">
                        <AutoCompleteTextView android:id="@+id/dropTipoLadrillo"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="none"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- A.2 Área -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="A.2  Área de la losa"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilArea"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Área (m²)" android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etArea"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:layout_marginBottom="12dp"/>

                    <!-- A.3 Acero — igual que zapatas/columnas/vigas -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="A.3  Acero de refuerzo fy=4200"
                                android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Viguetas + refuerzo de temperatura"
                                android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.7" android:layout_marginTop="1dp"/>
                        </LinearLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVerTablaAcero"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📐 ASTM A615" android:textSize="11sp"
                            android:textColor="@color/mat_acero"
                            android:minHeight="0dp" android:paddingVertical="0dp"/>
                    </LinearLayout>

                    <!-- Col headers removed — new item_acero_fila.xml has built-in mode selector -->


                    <LinearLayout android:id="@+id/containerFilasAcero"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarBarra"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="+ Agregar barra"
                        android:textColor="@color/mat_acero" android:textSize="12sp"
                        android:minHeight="0dp" android:paddingVertical="4dp"/>

                    <!-- Divider + botones -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:layout_marginTop="10dp" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcular"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Calcular materiales" android:layout_marginEnd="8dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnLimpiar"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Limpiar" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <include layout="@layout/include_resultados_card"/>
        <include layout="@layout/include_presupuesto_card"/>
        <View android:layout_width="match_parent" android:layout_height="24dp"/>
    </LinearLayout>
</ScrollView>
