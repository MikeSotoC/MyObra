<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    >
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="24dp">
        <FrameLayout android:layout_width="match_parent" android:layout_height="160dp"
            android:background="?attr/colorPrimaryContainer">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="fitXY" android:alpha="0.7"
                app:srcCompat="@drawable/ic_header_falsopiso"
                android:contentDescription="@string/title_falsopiso"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_gravity="bottom" android:padding="16dp"
                android:orientation="vertical" android:background="#99000000">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/title_falsopiso"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/white"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/desc_falsopiso"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="#CCffffff"/>
            </LinearLayout>
        </FrameLayout>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_margin="12dp" app:cardElevation="2dp" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/label_datos_entrada"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorPrimary" android:layout_marginBottom="12dp"/>
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilProporcion"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="@string/label_proporcion" android:layout_marginBottom="10dp">
                    <AutoCompleteTextView android:id="@+id/dropProporcion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilArea"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="@string/label_area" android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etArea"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilEspesor"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="@string/label_espesor" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEspesor"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:text="10"/>
                </com.google.android.material.textfield.TextInputLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcular"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="@string/label_calcular" android:layout_marginEnd="6dp"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnLimpiar"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="@string/label_limpiar" android:layout_marginStart="6dp"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTablaCapeco"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="📊 Ver tabla CAPECO concreto"
                    android:textColor="?attr/colorPrimary" android:textSize="12sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <include layout="@layout/include_resultados_card" android:id="@+id/cardResultadosWrapper"/>
        <include layout="@layout/include_presupuesto_card" android:id="@+id/cardPresupuestoWrapper"/>
    </LinearLayout>
</ScrollView>
