<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Page header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/colorPrimary"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Presupuesto General"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumen consolidado por partida"
                    android:textSize="12sp"
                    android:textColor="#CCffffff"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- PDF export button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportarPdf"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exportar PDF"
                android:textSize="12sp"
                android:enabled="false"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- ── Empty state ── -->
        <LinearLayout
            android:id="@+id/tvSinDatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="48dp"
            android:paddingHorizontal="32dp">
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:srcCompat="@drawable/ic_nav_presupuesto"
                android:alpha="0.2"
                android:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="Sin datos"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No hay cálculos disponibles aún"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa datos en cada sección del menú lateral y presiona Calcular"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ── Main card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPresupuestoGeneral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardElevation="3dp"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Project info band -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorSurfaceVariant"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">
                    <TextView
                        android:id="@+id/tvNombreProyectoPresup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>
                    <TextView
                        android:id="@+id/tvPropietarioPresup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp"/>
                    <TextView
                        android:id="@+id/tvUbicacionPresup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Column headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/colorPrimary">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="PARTIDA"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10"
                        android:textColor="@color/white"/>
                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="MATERIALES"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="@color/white"/>
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="M. OBRA"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="@color/white"/>
                    <TextView
                        android:layout_width="95dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="TOTAL"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="#FFD8C0"/>
                </LinearLayout>

                <!-- Dynamic rows -->
                <LinearLayout
                    android:id="@+id/containerPartidas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- Subtotals row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/colorSurfaceVariant">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="SUBTOTALES"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                    <TextView
                        android:id="@+id/tvTotalMateriales"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>
                    <TextView
                        android:id="@+id/tvTotalManoObra"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>
                    <View android:layout_width="95dp" android:layout_height="1dp"/>
                </LinearLayout>

                <!-- Grand total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/colorPrimaryContainer">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="COSTO TOTAL DE OBRA"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimaryContainer"/>
                    <TextView
                        android:id="@+id/tvGranTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"/>
                </LinearLayout>

                <!-- Note -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="* Precios aplicados desde Configuración. Proporciones según CAPECO Perú."
                    android:textSize="10sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View android:layout_width="match_parent" android:layout_height="24dp"/>
    </LinearLayout>
</ScrollView>
